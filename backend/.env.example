# Copy this file to .env and fill in real values. NEVER commit the real .env file.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/smart-grocery?retryWrites=true&w=majority

# JWT secret - generate a long random string, e.g. `openssl rand -base64 48`
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Razorpay TEST mode keys (from https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret_here

# Comma-separated list of origins allowed to call this API
CLIENT_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
